# صندوقچی / BoursePilot environment example
# Copy to .env and fill values. Never commit real secrets.

PRODUCT_NAME=صندوقچی

# --- BRS Market Data (required for live data) ---
BRS_API_KEY=
BRS_BASE_URL=https://Api.BrsApi.ir/Tsetmc
BRS_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36
BRS_TIMEOUT_SECONDS=30
BRS_MAX_RETRIES=2
BRS_ALL_SYMBOLS_TYPE=1
MARKET_DATA_PROVIDER=brs

# --- Telegram (later phases) ---
TELEGRAM_BOT_TOKEN=
# برای کانال معمولاً -100... و ربات باید ادمین کانال باشد
TELEGRAM_CHAT_ID=

# --- Snapshot / ranking ---
SNAPSHOT_DIR=data/snapshots
SCORING_CONFIG_PATH=config/scoring.yaml
FETCH_NAV_IN_DAILY_RANK=false
NAV_FETCH_WORKERS=4

